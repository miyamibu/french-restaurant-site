// Prisma schema for Bistro reservation system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SeatType {
  MAIN
  ROOM1
  ROOM2
}

enum ReservationStatus {
  CONFIRMED
  CANCELLED
  DONE
  NOSHOW
}

enum ReservationType {
  NORMAL
  PRIVATE_BLOCK
}

enum ServicePeriod {
  LUNCH
  DINNER
}

enum PrivateBlockAuditResult {
  CREATED
  NO_OP
  RELEASED
}

enum PrivateBlockAuditSource {
  PUBLIC_FORM
  ADMIN_SHARED_BASIC
}

model Reservation {
  id                    String                 @id @default(cuid())
  date                  String
  servicePeriod         ServicePeriod
  reservationType       ReservationType        @default(NORMAL)
  seatType              SeatType
  partySize             Int
  arrivalTime           String?
  name                  String
  phone                 String
  note                  String?
  status                ReservationStatus      @default(CONFIRMED)
  lineUserId            String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  privateBlockAuditLogs PrivateBlockAuditLog[]

  @@index([date, servicePeriod])
  @@index([date, servicePeriod, reservationType])
}

model PrivateBlockAuditLog {
  id            String                  @id @default(cuid())
  reservationId String?
  reservation   Reservation?            @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  date          String
  servicePeriod ServicePeriod
  result        PrivateBlockAuditResult
  source        PrivateBlockAuditSource
  actorName     String?
  requestId     String
  ipAddress     String?
  userAgent     String?
  note          String?
  createdAt     DateTime                @default(now())

  @@index([date, servicePeriod, createdAt])
  @@index([reservationId, createdAt])
}

model ReservationRateLimitEvent {
  id            String         @id @default(cuid())
  keyHash       String
  scope         String
  date          String?
  servicePeriod ServicePeriod?
  createdAt     DateTime       @default(now())

  @@index([keyHash, scope, createdAt])
  @@index([date, servicePeriod, scope, createdAt])
}

model BusinessDay {
  id       String  @id @default(cuid())
  date     String  @unique
  isClosed Boolean @default(false)
  note     String?
}

model MenuItem {
  id          String  @id @default(cuid())
  title       String
  description String
  price       Int
  sortOrder   Int     @default(0)
  isPublished Boolean @default(true)
}

model Photo {
  id          String  @id @default(cuid())
  url         String
  caption     String
  category    String  @default("food")
  sortOrder   Int     @default(0)
  isPublished Boolean @default(true)
}
